    {
      "name": "Content Upload (Teacher)",
      "item": [
        {
          "name": "Upload Content - Maths",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Algebra Basics - Chapter 1"
                },
                {
                  "key": "description",
                  "value": "Introduction to algebraic equations and solving"
                },
                {
                  "key": "subject_id",
                  "value": "1"
                },
                {
                  "key": "start_time",
                  "value": "2026-04-26T09:00:00Z"
                },
                {
                  "key": "end_time",
                  "value": "2026-04-26T18:00:00Z"
                },
                {
                  "key": "rotation_duration",
                  "value": "5"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "path/to/image.jpg"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/content/upload",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "content", "upload"]
            }
          }
        },
