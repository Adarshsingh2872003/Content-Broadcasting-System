            "url": {
              "raw": "http://localhost:5000/api/approval/reject",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval", "reject"]
            }
          }
        },
        {
          "name": "View All Contents by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/approval?status=pending",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        }
      ]
