              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval", "approve"]
            }
          }
        },
        {
          "name": "Reject Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
