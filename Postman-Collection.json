{
  "info": {
    "_postman_id": "content-broadcasting-api",
    "name": "Content Broadcasting System",
    "description": "API Collection for Content Broadcasting System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"teacher\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Principal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Principal Smith\",\n  \"email\": \"principal@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"principal\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set(\"teacher_token\", jsonData.data.token);",
                  "  pm.environment.set(\"teacher_id\", jsonData.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Principal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set(\"principal_token\", jsonData.data.token);",
                  "  pm.environment.set(\"principal_id\", jsonData.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Content Upload (Teacher)",
      "item": [
        {
          "name": "Upload Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Algebra Basics",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Introduction to algebraic equations",
                  "type": "text"
                },
                {
                  "key": "subject_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "start_time",
                  "value": "2026-04-26T09:00:00Z",
                  "type": "text"
                },
                {
                  "key": "end_time",
                  "value": "2026-04-26T18:00:00Z",
                  "type": "text"
                },
                {
                  "key": "rotation_duration",
                  "value": "5",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "path/to/image.jpg"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/content/upload",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "content", "upload"]
            }
          }
        },
        {
          "name": "Get My Contents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/content/my-contents",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "content", "my-contents"]
            }
          }
        }
      ]
    },
    {
      "name": "Approval Workflow (Principal)",
      "item": [
        {
          "name": "Get Pending Contents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/approval/pending",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval", "pending"]
            }
          }
        },
        {
          "name": "Approve Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_id\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/approval/approve",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval", "approve"]
            }
          }
        },
        {
          "name": "Reject Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_id\": 2,\n  \"rejection_reason\": \"File quality is not good enough\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/approval/reject",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval", "reject"]
            }
          }
        },
        {
          "name": "Get All Contents (by status)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{principal_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/approval?status=pending",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "approval"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        }
      ]
    },
